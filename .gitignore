# === 编辑器 / IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === AI 编程工具自动产生的目录 ===
.claude/        # Claude Code 运行时自动创建（plans、skills、local 等）
.codex/         # Codex CLI 可能产生的目录
.cursor/        # Cursor 项目级缓存/配置
.kimi/          # Kimi Code CLI 可能产生的目录
.agents/        # 通用 Agent 工具目录

# === OS 临时文件 ===
.DS_Store
Thumbs.db
desktop.ini

# === Skill 运行时输出（防止在仓库内测试时误提交）===
auto_debug_extracted_*.log
auto_debug_report_*.md

# === 临时目录 ===
temp/
tmp/
